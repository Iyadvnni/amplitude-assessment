<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Your Landing Page</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#ffffff;
color:#111;
}

.hero{
padding:80px 20px;
text-align:center;
background:#f5f5f5;
}

.hero h1{
font-size:36px;
margin-bottom:15px;
}

.hero p{
font-size:18px;
margin-bottom:20px;
}

.btn{
display:inline-block;
background:black;
color:white;
padding:15px 25px;
border-radius:8px;
text-decoration:none;
}

.section{
padding:50px 20px;
text-align:center;
}

footer{
padding:30px;
text-align:center;
background:#111;
color:white;
}
</style>
</head>

<body>

<section class="hero">
<h1>Your Main Headline</h1>
<p>Your short description here</p>

<a href="#" class="btn">
Get Started
</a>
</section>

<section class="section">
<h2>About</h2>
<p>Add your content here</p>
</section>

<footer>
Copyright 2026
</footer>

</body>
</html>
